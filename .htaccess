RewriteEngine On

# landing page
RewriteRule ^$ landing.php [L]

# user dashboard
RewriteRule ^user$ user.php [L]

# auth directory routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^auth/([a-zA-Z0-9_-]+)$ auth/$1.php [L]

# api directory routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/([a-zA-Z0-9_-]+)$ api/$1.php [L]

# hide .php extension for direct routes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L]
