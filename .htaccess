RewriteEngine On
RewriteBase /plagiarism/

# landing page
RewriteRule ^$ landing.php [L]

# hide .php extension for direct routes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L]

# optional: force remove .php from URL
RewriteCond %{THE_REQUEST} \s/+plagiarism/([^.]+)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]